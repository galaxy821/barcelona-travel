---
import Layout from '../layouts/Layout.astro';
import MasonryGrid from '../components/MasonryGrid.jsx';
import accommodations from '../data/accommodations.js';
---

<Layout title="숙소 - Barcelona Travel Guide 2025" activeTab="accommodation">
  <div class="sec-head">
    <h2 class="sec-head__title">추천 숙소</h2>
    <p class="sec-head__sub">세비야 구시가지 중심, 위치와 가성비가 좋은 아파트형 숙소</p>
  </div>
  <MasonryGrid client:visible items={accommodations} />
</Layout>
