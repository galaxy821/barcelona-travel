---
import Layout from '../layouts/Layout.astro';
import MasonryGrid from '../components/MasonryGrid.jsx';
import restaurants from '../data/restaurants.js';

const totalCount = restaurants.main.length + restaurants.sagrada.length + restaurants.dessert.length;
---

<Layout title="식당 - Barcelona Travel Guide 2025" activeTab="restaurants">
  <div class="sec-head">
    <h2 class="sec-head__title">추천 식당</h2>
    <p class="sec-head__sub">현지 맛집부터 한국인 입맛 저격 식당까지 {totalCount}곳</p>
  </div>

  <MasonryGrid client:visible items={restaurants.main} />

  <h3 class="sub-label"><i class="fa-solid fa-church"></i> 사그라다 파밀리아 주변 맛집</h3>
  <MasonryGrid client:visible items={restaurants.sagrada} />

  <h3 class="sub-label"><i class="fa-solid fa-ice-cream"></i> 디저트 &middot; 카페</h3>
  <MasonryGrid client:visible items={restaurants.dessert} />
</Layout>
