---
import Layout from '../layouts/Layout.astro';
import MasonryGrid from '../components/MasonryGrid.jsx';
import attractions from '../data/attractions.js';
---

<Layout title="가볼만한 곳 - Barcelona Travel Guide 2025" activeTab="attractions">
  <div class="sec-head">
    <h2 class="sec-head__title">가볼만한 곳</h2>
    <p class="sec-head__sub">스페인 광장부터 알카사르까지, 세비야 필수 관광지 {attractions.length}곳</p>
  </div>
  <MasonryGrid client:visible items={attractions} wide={true} />
</Layout>
