---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.jsx';
import festivals from '../data/festivals.js';
---

<Layout title="축제 - Barcelona Travel Guide 2025" activeTab="festivals">
  <div class="sec-head">
    <h2 class="sec-head__title">축제 정보</h2>
    <p class="sec-head__sub">바르셀로나 크리스마스 시즌 마켓 &amp; 이벤트 총정리 (2025년)</p>
  </div>

  <div class="highlight-box" style="margin-bottom: 28px;" set:html={festivals.intro.html} />

  <h3 class="sub-label"><i class="fa-solid fa-store"></i> 주요 크리스마스 마켓</h3>
  <div class="grid">
    {festivals.markets.map((item, i) => (
      <Card client:visible data={item} />
    ))}
  </div>

  <h3 class="sub-label"><i class="fa-solid fa-calendar-star"></i> 그 외 크리스마스 일정</h3>
  <div class="grid">
    {festivals.events.map((item, i) => (
      <Card client:visible data={item} />
    ))}
  </div>
</Layout>
