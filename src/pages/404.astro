---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="페이지를 찾을 수 없습니다 - Barcelona Travel Guide 2025" activeTab="">
  <div class="sec-head">
    <h2 class="sec-head__title">404</h2>
    <p class="sec-head__sub">요청하신 페이지를 찾을 수 없습니다</p>
  </div>
  <div style="text-align:center; padding:40px 20px;">
    <p style="font-size:1.1rem; color:#666; margin-bottom:24px;">
      URL을 다시 확인해주세요. 아래 메뉴에서 원하는 페이지로 이동할 수 있습니다.
    </p>
    <div style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center;">
      <a href={`${base}/`} class="link-btn">🏨 숙소</a>
      <a href={`${base}/attractions/`} class="link-btn">📍 가볼만한 곳</a>
      <a href={`${base}/restaurants/`} class="link-btn">🍽️ 식당</a>
      <a href={`${base}/shopping/`} class="link-btn">🛍️ 쇼핑</a>
      <a href={`${base}/daytrips/`} class="link-btn">🚌 근교 투어</a>
      <a href={`${base}/festivals/`} class="link-btn">🎄 축제</a>
    </div>
  </div>
</Layout>

<style>
  .link-btn {
    display: inline-block;
    padding: 10px 20px;
    background: #2563eb;
    color: #fff !important;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s;
  }
  .link-btn:hover {
    background: #1d4ed8;
  }
</style>
